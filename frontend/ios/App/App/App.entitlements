<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- APNs production environment — required for push notifications on
         App Store and TestFlight builds. The Xcode project must also have
         Push Notifications added under Signing & Capabilities. -->
    <key>aps-environment</key>
    <string>production</string>
</dict>
</plist>
